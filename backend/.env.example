# App Configuration
APP_NAME="Core Fleet Management API"
ENV=development
DEBUG=true
API_V1_STR=/api/v1

# Security
SECRET_KEY=supersecretjwtkeythatis32byteslongatleastforsecurity123!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fleet_management
# Fallback database URL if not using split postgres config (e.g. for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fleet_management

# Redis & Celery
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Mail Configuration
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=user@example.com
SMTP_PASSWORD=password
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME="Core Fleet Management"

# First Superuser / Admin User
FIRST_SUPERUSER=admin@fleet.com
FIRST_SUPERUSER_PASSWORD=AdminPassword123!
